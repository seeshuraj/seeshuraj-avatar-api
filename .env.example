NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-r1-0528-qwen3-8b

# Azure Neural TTS
SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
